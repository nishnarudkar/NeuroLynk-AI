# Copy this file to .env and fill in your values
# .env is gitignored — never commit real credentials

DAGSHUB_USERNAME=your_dagshub_username
DAGSHUB_TOKEN=your_dagshub_token_here

# ── Healthcare AI Agent Configuration ─────────────────────────────────────────

# LLM provider to use for clinical summary generation.
# Options: "mock" (offline/dev, no API call) | "openai" (requires LLM_API_KEY)
LLM_PROVIDER=mock

# Model name passed to the LLM API (only used when LLM_PROVIDER=openai)
LLM_MODEL=gpt-4o-mini

# API key for the LLM provider (only required when LLM_PROVIDER=openai)
LLM_API_KEY=your_openai_api_key_here

# Seconds to wait for an LLM response before timing out and using the fallback summary
LLM_TIMEOUT_SECONDS=8

# Version string reported in agent_metadata of every screening response
AGENT_VERSION=1.0.0-hackathon

# Maximum number of screening sessions to keep in memory (FIFO eviction when exceeded)
AGENT_MAX_SESSIONS=100
